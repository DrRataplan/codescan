{
	"compilerOptions": {
		"baseUrl": ".",
		"declaration": true,
		"moduleResolution": "bundler",
		"strict": true,
		"lib": ["es6", "es2017", "esnext.asynciterable"],
		"module": "ESNext",
		"noImplicitAny": true,
		"outDir": "./built",
		"strict": false,
		"target": "ESNext",
		"allowImportingTsExtensions": true
	},
	"include": ["./index.ts"],
	"exclude": ["./**/*.d.ts"]
}
